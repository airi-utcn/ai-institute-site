{
  "kind": "collectionType",
  "collectionName": "publications",
  "info": {
    "singularName": "publication",
    "pluralName": "publications",
    "displayName": "Publication"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "openAlexId": {
      "type": "string",
      "unique": true
    },
    "sourceKind": {
      "type": "enumeration",
      "enum": [
        "manual",
        "openalex",
        "merged"
      ],
      "default": "manual"
    },
    "verificationStatus": {
      "type": "enumeration",
      "enum": [
        "imported",
        "reviewed",
        "curated"
      ],
      "default": "curated"
    },
    "graphEligible": {
      "type": "boolean",
      "default": true
    },
    "listingEligible": {
      "type": "boolean",
      "default": true
    },
    "doi": {
      "type": "string"
    },
    "year": {
      "type": "integer"
    },
    "kind": {
      "type": "string"
    },
    "cited_by": {
      "type": "integer",
      "default": 0
    },
    "abstract": {
      "type": "text"
    },
    "topics": {
      "type": "json"
    },
    "community": {
      "type": "integer"
    },
    "communityLabel": {
      "type": "string"
    },
    "lastImportedAt": {
      "type": "datetime"
    },
    "lastGraphIndexedAt": {
      "type": "datetime"
    },
    "embeddingModel": {
      "type": "string"
    },
    "embeddingUpdatedAt": {
      "type": "datetime"
    },
    "embeddingSourceHash": {
      "type": "string"
    },
    "embedding": {
      "type": "json"
    },
    "description": {
      "type": "richtext"
    },
    "pdfFile": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "files"
      ]
    },
    "bibFile": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "files"
      ]
    },
    "attachments": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": [
        "files",
        "images",
        "videos",
        "audios"
      ]
    },
    "metadata": {
      "type": "json"
    },
    "rawImportMetadata": {
      "type": "json"
    },
    "domain": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::department.department",
      "inversedBy": "publications"
    },
    "themes": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::research-theme.research-theme",
      "inversedBy": "publications"
    },
    "authors": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::person.person",
      "inversedBy": "publications"
    },
    "projects": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::project.project",
      "inversedBy": "publications"
    },
    "resources": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::resource.resource"
    },
    "outgoingGraphLinks": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::graph-link.graph-link",
      "mappedBy": "source"
    },
    "incomingGraphLinks": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::graph-link.graph-link",
      "mappedBy": "target"
    }
  }
}
