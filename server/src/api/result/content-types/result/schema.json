{
  "kind": "collectionType",
  "collectionName": "results",
  "info": {
    "singularName": "result",
    "pluralName": "results",
    "displayName": "Result",
    "description": "Research outputs: datasets, code, press releases, videos, and other deliverables"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "description": {
      "type": "text",
      "maxLength": 500
    },
    "body": {
      "type": "dynamiczone",
      "components": [
        "shared.section",
        "shared.rich-text",
        "shared.media",
        "shared.slider"
      ]
    },
    "attachments": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": [
        "files",
        "images",
        "videos",
        "audios"
      ]
    },
    "publishedDate": {
      "type": "date"
    },
    "projects": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::project.project",
      "inversedBy": "results"
    }
  }
}
